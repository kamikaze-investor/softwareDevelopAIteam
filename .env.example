# AI Development Team OS — 環境変数サンプル
# このファイルをコピーして .env を作成する
# .env は絶対にコミットしない

# Backend API
PORT=3000
# API authentication token (empty = authentication disabled)
API_TOKEN=your_api_token_here

# Claude API（Developer AI / CTO AI / Context Manager AI）
CLAUDE_API_KEY=your_claude_api_key_here

# Gemini API（Meta Reviewer AI / Project Reviewer AI）
# 別プロバイダにすることで相関バイアスを排除する
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=

# OpenAI API（Codex CLI — Developer AI サブプロバイダー）
# Claude Code が重い処理向き、Codex は局所的なコード編集向き
# 使わない場合は空のままでよい
OPENAI_API_KEY=your_openai_api_key_here

# GitHub
# GITHUB_TOKEN は git push と gh CLI 両方で使用する
# gh CLI の認証: export GH_TOKEN=$GITHUB_TOKEN または gh auth login
GITHUB_TOKEN=your_github_token_here
GIT_USER_NAME=your_git_username
GIT_USER_EMAIL=your_git_email

# Sandbox
CONTROL_REPO_PATH=/srv/ai-team/softwareDevelopAIteam  # このリポジトリ（read-only mount）
TARGET_REPO_PATH=/srv/ai-team/repos/target-project    # AIが開発する対象（read-write mount）

# Worker
API_BASE_URL=http://localhost:3000
WORKER_POLL_INTERVAL_MS=5000
