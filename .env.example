# AI Development Team OS — 環境変数サンプル
# このファイルをコピーして .env を作成する
# .env は絶対にコミットしない

# Backend API
PORT=3000

# Claude API
CLAUDE_API_KEY=your_claude_api_key_here

# GitHub
GITHUB_TOKEN=your_github_token_here
GIT_USER_NAME=your_git_username
GIT_USER_EMAIL=your_git_email

# Sandbox
TARGET_REPO_PATH=/srv/ai-team/repos/target-project

# Worker
WORKER_POLL_INTERVAL_MS=5000
